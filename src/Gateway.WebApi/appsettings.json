{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "network-route": {
        "ClusterId": "network-cluster",
        "Match": { "Path": "/api/network/{**catch-all}" }
      },
      "sales-route": {
        "ClusterId": "sales-cluster",
        "Match": { "Path": "/api/sales/{**catch-all}" }
      }
    },
    "Clusters": {
      "network-cluster": {
        "Destinations": {
          "network": { "Address": "https+http://Network" }
        }
      },
      "sales-cluster": {
        "Destinations": {
          "sales": { "Address": "https+http://Sales" }
        }
      }
    }
  }
}
